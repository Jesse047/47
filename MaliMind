/* LOGIN */
async function login(){
  const res = await fetch("/api/login",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body: JSON.stringify({
      email: email.value,
      password: pass.value
    })
  });
  const data = await res.json();
  token = data.token;
  loadDash();
