import express from "express";
import fetch from "node-fetch";
import cors from "cors";
import jwt from "jsonwebtoken";

const app = express();
app.use(express.json());
app.use(cors());

const SECRET = "supersecretkey";
const USERS = [];

/* =========================
FRONTEND (served inline)
========================= */
app.get("/", (req, res) => {
res.send(`

