/* DASHBOARD */
async function loadDash(){
  const res = await fetch("/api/dashboard",{
    headers:{Authorization:token}
  });
  const data = await res.json();
  document.getElementById("dash").innerText =
    "Balance: KSh " + data.balance;
}

/* MPESA */
async function pay(){
  await fetch("/api/mpesa",{
    method:"POST",
    headers:{
